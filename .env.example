# Copy this to .env and fill in your bot token
DISCORD_TOKEN=your-bot-token-here

# Optional: Giphy API key for random birthday GIFs (get one free at developers.giphy.com)
# GIPHY_API_KEY=your-giphy-api-key-here

# Optional: how many days back to auto-post belated notices on startup (default 7)
# CATCHUP_DAYS=7
