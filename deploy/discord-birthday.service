[Unit]
Description=Discord Birthday Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/pi/discord-birthday
ExecStart=/home/pi/discord-birthday/.venv/bin/python bot.py
Restart=on-failure
RestartSec=10
User=pi

[Install]
WantedBy=multi-user.target
