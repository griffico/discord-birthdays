[Unit]
Description=Discord Birthday Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/pi/repos/discord-birthdays
ExecStart=/home/pi/repos/discord-birthdays/.venv/bin/python bot.py
Restart=on-failure
RestartSec=10
User=pi

[Install]
WantedBy=multi-user.target
